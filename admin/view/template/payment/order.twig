<div id="payContent">
  <div class="container-fluid">
    <div class="card mb-3">
      <div class="card-header"><i class="fa-solid fa fa-credit-card"></i> Pay. Payments</div>
      <div class="card-body">       
        <table class="table table-bordered">
          <thead>
            <tr>
              <td class="text-start">{{text_order_orderid}}</td>
              <td class="text-start">{{text_order_status}}</td>
              <td class="text-start">{{text_order_pm}}</td>
              <td class="text-start">{{text_order_amount_cart}}</td>
              <td class="text-start">{{text_order_amount_pay}}</td>
              <td class="text-start">{{text_order_amount_refunded}}</td>
            </tr>
          </thead>
          <tbody id="order-products">
            <tr>
              <td class="text-start">{{ paynl_transaction_id }}</td>
              <td class="text-start">{{ paynl_status_name }}</td>
              <td class="text-start">{{ payment_method }}</td>
              
              <td class="text-start">{{ currency_code }} {{ paynl_cart_amount }}</td>    
              <td class="text-start">{{paynl_currency}} {{ paynl_amount }} {% if (paynl_amount_captured != 0) and (paynl_amount_captured != paynl_amount) %}({{paynl_amount_captured}} {{text_order_amount_captured}}){% endif %} </td>
              <td class="text-start">{{paynl_currency}} {{ paynl_amount_refunded }}</td>              
            </tr>
          </tbody>            
        </table>
        <div id="payFunction">
          {% if show_refund or show_capture %} 
            <div class="row mb-3">
              <input type="hidden" id="ajaxURL" value="{{ ajax_url }}"></input>
              <input type="hidden" id="payOrderCurrency" value="{{ paynl_currency }}"></input>
              <input type="hidden" id="confirmMessage" value="{{ text_confirm }}"></input>              
              <input type="hidden" id="nanErrorMessage" value="{{ text_error_nan }}"></input>
              <label for="payOrderAmount" class="col-form-label" style="display: inline-block;text-align: left;width: auto;">{{text_description}} ({{ paynl_currency }})</label>
              <div class="col-sm-2">                  
                <input type="number" step="0.01" placeholder="0,00" class="form-control" name="payOrderAmount" id="payOrderAmount" value="{{ paynl_amount_value }}"/>             
              </div>
              <a id="payOrderButton" class="btn btn-primary col-sm-1" target="_BLANK">{{text_button}}</a>
            </div> 
          {% endif %}          
        </div>
      </div>
    </div>
  </div>
</div>

<div id="modal-pay" class="modal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Pay.</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
          <p id="payMessage"></p>
          <div id="pay-modal-buttons" style="text-align: end;">
            <a id="paymodalcancel" class="btn btn-secondary col-sm-1" target="_BLANK" style="width: 80px;">Cancel</a>
            <a id="paymodalconfirm" class="btn btn-primary col-sm-1" target="_BLANK" style="width: 80px;">Confirm</a>
          </div>          
      </div>
    </div>
  </div>
</div>

<div id="modal-pay-success" class="modal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Pay.</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
          <p id="paySuccessMessage"></p>
          <div id="pay-modal-buttons" style="text-align: end;">
            <a id="paymodalclose" class="btn btn-primary col-sm-1" target="_BLANK" style="width: 80px;">Ok</a>
          </div>          
      </div>
    </div>
  </div>
</div>